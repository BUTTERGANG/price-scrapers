# Copy this file to .env and fill in your values

# PostgreSQL connection (NeonDB or Replit built-in)
# NEONDB1 takes priority over DATABASE_URL if both are set
NEONDB1=postgresql://user:pass@host/dbname?sslmode=require
# DATABASE_URL=postgresql://postgres:password@helium/heliumdb?sslmode=disable

# Required for Needler's circular (Claude vision analysis) and Telegram /ask
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required for Telegram bot notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Kroger API credentials (register at https://developer.kroger.com)
# Note: Kroger weekly ads work without credentials via the DACS public API.
# These are only needed for the Kroger product search API.
# Add to config/stores.json under "kroger": { "client_id": "...", "client_secret": "..." }
